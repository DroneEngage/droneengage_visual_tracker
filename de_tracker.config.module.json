{
    "module_id": "VIS_TRK_PRO",
    "s2s_udp_target_ip": "127.0.0.1",
    "s2s_udp_target_port": "60000",
    "s2s_udp_listening_ip": "127.0.0.1",
    "s2s_udp_listening_port": "60053",
    "s2s_udp_packet_size": "8192",
    // tracker_algorithm_index: 
    /*
    enum ENUM_TRACKER_TYPE 
    {
        TRACKER_BOOSTING    = 0,
        TRACKER_MIL         = 1,  
        TRACKER_KCF         = 2,
        TRACKER_TLD         = 3,  
        TRACKER_MEDIANFLOW  = 4,
        TRACKER_GOTURN      = 5,  
        TRACKER_MOSSE       = 6,
        TRACKER_CSRT        = 7,  
    };
    */
    "camera": {
        // Specific Module Parameters
        "source_video_device"               : "/dev/video0",
        //"output_video_device": "/dev/video3"
        //"source_video_device_name"          : "DE-CAM1", //"SIM-CAM1", //"C270 HD WEBCAM",  // DE-RPI,DE-THERMAL,
        "output_video_device_name"          : "DE-TRK"
        //"desired_input_width"               : 1280,
        //"desired_input_height"              : 720
    },
    "tracking": {
        "tracker_algorithm_index": 7,
        "camera_orientation": 0, // 0b0000 bit:0 horizontal/vertical, bits1,2: rotation (0,90,180,270)
        "camera_flipped": false,
        "tracking_camera_direction": 1,  // none, front , back , down , up 
        "crosshair": false
    },
    "advanced_tracking": {
        "frames_to_skip_between_messages": 3,
        "frame_to_skip_between_track_process": 2,
        "ema_alpha_base": 0.3,
        "ai_confidence_threshold": 0.6,         // Minimum confidence for AI detections
        "ai_stability_threshold": 0.75,         // Minimum stability score for re-initialization
        "ai_detection_buffer_size": 5,          // Number of recent detections to consider
        "ai_detection_timeout_ms": 2000,        // Maximum age of detections in buffer
        "ai_assisted_recovery_enabled": true,   // Enable AI-assisted recovery
        "ai_priority": true,                    // Prioritize AI detections over current tracking
        "ai_priority_distance_threshold": 0.2,  // Distance threshold for "out of square" (20% of image diagonal)
        "tracker_lost_timeout_ms": 10000        // Timeout for manual intervention (when AI disabled)
    }
}