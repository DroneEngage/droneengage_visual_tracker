[
    {
        "name": "Tracking Camera Settings",
        "template": {
            "Camera": {
                "fieldName": "camera",
                "type": "object",
                "fields": {
                    "source video device": {
                        "fieldName": "source_video_device",
                        "order":1,
                        "type": "text",
                        "defaultvalue": "/dev/video1",
                        "optional": true,
                        "desc": "video input by number."
                    },
                    "source_video_device_name": {
                        "order":2,
                        "type": "text",
                        "defaultvalue": "DE-RPI",
                        "optional": true,
                        "desc": "video input by name."
                    },
                    "output_video_device": {
                        "order":3,
                        "type": "text",
                        "defaultvalue": "/dev/video1",
                        "optional": true,
                        "desc": "virtual video output by number."
                    },
                    "output_video_device_name": {
                        "order":4,
                        "type": "text",
                        "defaultvalue": "DE-TRK",
                        "optional": true,
                        "desc": "virtual video output by name."
                    },
                    "desired_input_width": {
                        "order":5,
                        "type": "number",
                        "defaultvalue": 1280,
                        "optional": true,
                        "desc": "desired input width"
                    },
                    "desired_input_height": {
                        "order":6,
                        "type": "number",
                        "defaultvalue": 720,
                        "optional": true,
                        "desc": "desired input height"
                    }
                    
                },
                "optional": false,
                "desc": "serial port settings - ONLY ONE fcb_connection_uri"
            }
        }
    },
    { "name": "Tracking Settings",
        "template": {
            "Tracker Settings": {
                "fieldName": "tracking",
                "type": "object",
                "fields": {
                    "tracker algorithm index": {
                        "fieldName": "tracker_algorithm_index",
                        "order":1,
                        "type": "number",
                        "defaultvalue": 7,
                        "optional": false,
                        "desc": "(0-7)(BOOST,MIL,KCF,TLD,MEDIANFLOW,GOTURN,MOSSE,CSRT)"
                    },
                    "Camera Rotation": {
                        "fieldName": "camera_orientation",
                        "order":2,
                        "type": "number",
                        "defaultvalue": 0,
                        "optional": false,
                        "desc": "Camera Rotation (0:0,1:90,2:180,3:270)"
                    },
                    "Tracking Camera Direction": {
                        "fieldName": "tracking_camera_direction",
                        "order":3,
                        "type": "number",
                        "defaultvalue": 0,
                        "optional": false,
                        "desc": "(0:none,1:front,2:back,3:down,4:up)"
                    },
                    "Camera Flipped": {
                        "fieldName": "camera_flipped",
                        "order":4,
                        "type": "boolean",
                        "defaultvalue": false,
                        "optional": false,
                        "desc": "Camera flipped horizontally/vertically"
                    },
                    "Crosshair": {
                        "fieldName": "crosshair",
                        "order":5,
                        "type": "boolean",
                        "defaultvalue": true,
                        "optional": true,
                        "desc": "Display crosshair overlay during tracking"
                    }
                }
            }
        }
    },
    {
        "name": "Advanced Settings",
        "template": {
            "Advanced Settings": {
                "fieldName": "advanced_tracking",
                "type": "object",
                "fields": {
                    "frames to skip between messages": {
                        "fieldName": "frames_to_skip_between_messages",
                        "order":1,
                        "type": "number",
                        "defaultvalue": 3,
                        "optional": false,
                        "desc": "frames to skip between messages"
                    },
                    "frame to skip between track process": {
                        "fieldName": "frame_to_skip_between_track_process",
                        "order":2,
                        "type": "number",
                        "defaultvalue": 2,
                        "optional": false,
                        "desc": "frame to skip between track process"
                    },
                    "ema alpha base": {
                        "fieldName": "ema_alpha_base",
                        "order":3,
                        "type": "number",
                        "defaultvalue": 0.3,
                        "optional": false,
                        "desc": "EMA smoothing alpha (0.0-1.0)"
                    },
                    "ai_confidence_threshold": {
                        "fieldName": "ai_confidence_threshold",
                        "order":4,
                        "type": "number",
                        "defaultvalue": 0.6,
                        "optional": false,
                        "desc": "Minimum confidence for AI detections"
                    },
                    "ai_stability_threshold": {
                        "fieldName": "ai_stability_threshold", 
                        "order":5,
                        "type": "number",
                        "defaultvalue": 0.75,
                        "optional": false,
                        "desc": "Minimum stability score for re-initialization"
                    },
                    "ai_detection_buffer_size": {
                        "fieldName": "ai_detection_buffer_size",
                        "order":6,
                        "type": "number",
                        "defaultvalue": 5,
                        "optional": false,
                        "desc": "Number of recent detections to consider"
                    },
                    "ai_detection_timeout_ms": {
                        "fieldName": "ai_detection_timeout_ms",
                        "order":7,
                        "type": "number", 
                        "defaultvalue": 2000,
                        "optional": false,
                        "desc": "Maximum age of detections in buffer"
                    },
                    "ai_assisted_recovery_enabled": {
                        "fieldName": "ai_assisted_recovery_enabled",
                        "order":8,
                        "type": "boolean",
                        "defaultvalue": true,
                        "optional": false,
                        "desc": "Enable AI-assisted recovery"
                    },
                    "ai_priority": {
                        "fieldName": "ai_priority",
                        "order":9,
                        "type": "boolean",
                        "defaultvalue": true,
                        "optional": false,
                        "desc": "Prioritize AI detections over current tracking"
                    },
                    "ai_priority_distance_threshold": {
                        "fieldName": "ai_priority_distance_threshold",
                        "order":10,
                        "type": "number",
                        "defaultvalue": 0.2,
                        "optional": false,
                        "desc": "Distance threshold for 'out of square' (20% of image diagonal)"
                    },
                    "tracker_lost_timeout_ms": {
                        "fieldName": "tracker_lost_timeout_ms",
                        "order":11,
                        "type": "number",
                        "defaultvalue": 10000,
                        "optional": false,
                        "desc": "Timeout for manual intervention (when AI disabled)"
                    }
                }
            }
        }
    }
]